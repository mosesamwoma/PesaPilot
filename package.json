{
  "name": "pesapilot",
  "version": "2.1.0",
  "description": "AI-powered M-Pesa financial assistant. Parses your SMS transaction history, stores it in the cloud, and gives you real-time spending insights powered by Groq AI.",
  "main": "dist/whatsapp_bot.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node dist/whatsapp_bot.js",
    "start:baileys": "node dist/whatsapp_bot.js",
    "start:wwebjs": "node whatsapp/whatsapp_bot.js",
    "dev": "nodemon --exec ts-node --esm whatsapp/whatsapp_bot.ts",
    "dev:wwebjs": "nodemon whatsapp/whatsapp_bot.js",
    "build": "tsc && echo '{\"type\":\"module\"}' > dist/package.json",
    "build:watch": "tsc --watch",
    "api": "python -m uvicorn whatsapp.whatsapp_api:app --host 0.0.0.0 --port 8000 --reload",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rm -rf dist ./.baileys_auth ./.wwebjs_auth",
    "prebuild": "npm run clean"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosesamwoma/PesaPilot.git"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "mpesa",
    "ai",
    "groq",
    "financial",
    "baileys",
    "whatsapp-web.js",
    "typescript"
  ],
  "author": "Moses Amwoma",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mosesamwoma/PesaPilot/issues"
  },
  "homepage": "https://github.com/mosesamwoma/PesaPilot#readme",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "6.7.10",
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "node-cron": "^3.0.3",
    "pino": "^9.3.2",
    "puppeteer": "^22.0.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/pino": "^7.0.5",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}