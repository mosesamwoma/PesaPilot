# ─────────────────────────────────────────────────────
# PesaPilot — Environment Variables
# Fill in your keys, then rename this file to .env
# Never commit .env to GitHub
# ─────────────────────────────────────────────────────

# ============================================================
# Supabase — supabase.com/dashboard → Settings → API
# ============================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNzMyMjQ5NjAwLCJleHAiOjE3Mjc4MzU2MDB9.your-key-here

# ============================================================
# Groq — console.groq.com → API Keys
# ============================================================
GROQ_API_KEY=gsk_your-groq-api-key-here

# ============================================================
# App Configuration
# ============================================================
APP_ENV=production
DEBUG=false
SECRET_KEY=your-32-character-secret-key-here

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info

# ============================================================
# Database Configuration
# ============================================================
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=30
DB_QUERY_LIMIT=100
BATCH_SIZE=100

# ============================================================
# LLM / AI Configuration
# ============================================================
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=600
CACHE_TTL=300
API_TIMEOUT=20

# ============================================================
# WhatsApp Configuration
# ============================================================
# Your main Safaricom number — the number you send questions FROM
# Format: country code + number, no + sign (e.g. 254712345678)
WHATSAPP_MAIN_NUMBER=254755746130

# Your WhatsApp LID — internal ID WhatsApp assigns to your number
# To find it: run the bot, send a message, copy the value printed next to "From:" in the terminal
WHATSAPP_LID=115831308570778

# Your WhatsApp PIN — used for manual SMS entry (PIN-SMS_CONTENT)
WHATSAPP_PIN=1234

# ============================================================
# API Configuration
# ============================================================
API_URL=http://127.0.0.1:8000
WHATSAPP_API_PORT=8000

# ============================================================
# Node.js Configuration
# ============================================================
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=2048

# ============================================================
# Python Configuration
# ============================================================
PYTHONUNBUFFERED=1

# ============================================================
# Puppeteer/Chromium Configuration
# ============================================================
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ============================================================
# Timezone
# ============================================================
TZ=Africa/Nairobi

# ============================================================
# WhatsApp Library Configuration
# ============================================================


WHATSAPP_USE_PAIRING_CODE=false
BAILEYS_AUTH_PATH=./.baileys_auth
BAILEYS_LOG_LEVEL=info