# ─────────────────────────────────────────────────────
# PesaPilot — Environment Variables
# Fill in your keys, then rename this file to .env
# Never commit .env to GitHub
# ─────────────────────────────────────────────────────

# Supabase — supabase.com/dashboard → Settings → API
SUPABASE_URL=
SUPABASE_KEY=

# Groq — console.groq.com → API Keys
GROQ_API_KEY=

# App
APP_ENV=development
DEBUG=True
SECRET_KEY=dev-secret-key-12345

# Database
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=30
DB_QUERY_LIMIT=100
BATCH_SIZE=100

# LLM
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000
CACHE_TTL=300
API_TIMEOUT=20

# WhatsApp
# Your main Safaricom number — the number you send questions FROM
# Format: country code + number, no + sign (e.g. 254712345678)
WHATSAPP_MAIN_NUMBER=254712345678

# Your WhatsApp LID — internal ID WhatsApp assigns to your number
# To find it: run the bot, send a message, copy the value printed next to "From:" in the terminal
# Use this if WHATSAPP_MAIN_NUMBER does not authorize you
WHATSAPP_LID=115831308570778

WHATSAPP_API_URL=http://localhost:8000
WHATSAPP_API_PORT=8000
